---
import Layout from '../../../layouts/Layout.astro';
import { getLocalePaths, l, ui, type LocaleCode } from '../../../i18n/locales';
import { getCategories, getPhotos, getSiteSettings, type Photo } from '../../../lib/queries';
import { lightboxSrcset, srcsetFor, urlFor } from '../../../lib/image';

export async function getStaticPaths() {
  const [photos, categories] = await Promise.all([getPhotos(), getCategories()]);

  // Albums = categories: navigation on a photo page stays inside its album.
  const byAlbum = new Map<string, Photo[]>();
  for (const photo of photos) {
    const slug = photo.category?.slug ?? 'other';
    if (!byAlbum.has(slug)) byAlbum.set(slug, []);
    byAlbum.get(slug)!.push(photo);
  }

  const albums = categories
    .filter((cat) => byAlbum.has(cat.slug))
    .map((cat) => ({
      slug: cat.slug,
      title: cat.title,
      firstId: byAlbum.get(cat.slug)![0]._id,
      count: byAlbum.get(cat.slug)!.length,
    }));

  return getLocalePaths().flatMap(({ params }) =>
    photos.map((photo) => {
      const album = byAlbum.get(photo.category?.slug ?? 'other')!;
      const i = album.findIndex((p) => p._id === photo._id);
      return {
        params: { ...params, id: photo._id },
        props: {
          photo,
          album,
          index: i + 1,
          total: album.length,
          prev: album[(i - 1 + album.length) % album.length],
          next: album[(i + 1) % album.length],
          albums,
        },
      };
    }),
  );
}

interface Props {
  photo: Photo;
  album: Photo[];
  index: number;
  total: number;
  prev: Photo;
  next: Photo;
  albums: {
    slug: string;
    title: Photo['title'];
    firstId: string;
    count: number;
  }[];
}

const lang = Astro.params.lang as LocaleCode;
const t = ui[lang];
const { photo, album, index, total, prev, next, albums } = Astro.props;
const settings = await getSiteSettings();

const title = l(photo.title, lang);
const caption = l(photo.caption, lang);
const albumTitle = l(photo.category?.title, lang);
const pad = (n: number) => String(n).padStart(2, '0');

// Whole album for the fullscreen lightbox: swipe through it without leaving
// fullscreen, then Barba catches the page up on close.
const lightbox = {
  index: index - 1,
  labels: { zoom: t.zoom, close: t.close, prev: t.prev, next: t.next },
  photos: album.map((p) => ({
    url: `/${lang}/photo/${p._id}/`,
    src: urlFor(p.image, 1920),
    srcset: lightboxSrcset(p.image),
    width: p.image.width,
    height: p.image.height,
    msrc: p.image.lqip,
    alt: l(p.title, lang),
  })),
};
---

<Layout
  lang={lang}
  namespace="photo"
  pageTitle={title}
  title={`${title} — ${albumTitle} — ${settings.photographerName}`}
  description={caption || undefined}
  photographerName={settings.photographerName}
>
  <article class="pt-4 md:pt-8" id="top">
    <div class="detail-reveal mb-8 flex flex-wrap items-baseline justify-between gap-x-6 gap-y-5 text-[0.72rem] uppercase tracking-[0.22em]">
      <a href={`/${lang}/`} class="text-muted transition-colors duration-300 hover:text-ink">
        ← {t.back}
      </a>

      <!-- Album switcher: jump straight into another album -->
      <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label={t.albums}>
        {
          albums.map((album) => (
            <a
              href={`/${lang}/photo/${album.firstId}/`}
              class:list={[
                'transition-colors duration-300',
                album.slug === photo.category?.slug
                  ? 'text-ink underline decoration-accent decoration-2 underline-offset-4'
                  : 'text-muted hover:text-ink',
              ]}
              aria-current={album.slug === photo.category?.slug ? 'true' : undefined}
            >
              {l(album.title, lang)}
              <span class="ml-1 text-muted">{pad(album.count)}</span>
            </a>
          ))
        }
      </nav>

      <p class="text-muted" aria-label={`${index} ${t.counterOf} ${total}`}>
        <span class="text-ink">{pad(index)}</span>
        <span class="mx-1">/</span>
        <span>{pad(total)}</span>
      </p>
    </div>

    <!-- Side arrows (desktop) -->
    <a
      href={`/${lang}/photo/${prev._id}/`}
      data-nav-dir="prev"
      class="detail-arrow detail-arrow--prev"
      aria-label={`${t.prev}: ${l(prev.title, lang)}`}
    >
      ←
    </a>
    <a
      href={`/${lang}/photo/${next._id}/`}
      data-nav-dir="next"
      class="detail-arrow detail-arrow--next"
      aria-label={`${t.next}: ${l(next.title, lang)}`}
    >
      →
    </a>

    <figure data-detail-hero class="flex flex-col items-center">
      <button
        type="button"
        data-zoom-toggle
        data-cursor-label={t.zoom}
        aria-label={t.zoom}
        class="detail-hero__btn block"
      >
        <div
          class="photo-media detail-hero__media relative overflow-hidden rounded-[2px]"
          style={`aspect-ratio: ${photo.image.width} / ${photo.image.height}; background-image: url(${photo.image.lqip})`}
        >
          <img
            class="photo-img absolute inset-0 h-full w-full object-contain"
            src={urlFor(photo.image, 1920)}
            srcset={srcsetFor(photo.image)}
            sizes="(min-width: 1024px) 85vw, 100vw"
            width={photo.image.width}
            height={photo.image.height}
            alt={caption ? `${title} — ${caption}` : title}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </button>
    </figure>

    <script
      is:inline
      type="application/json"
      data-lightbox-data
      set:html={JSON.stringify(lightbox).replaceAll('<', '\\u003c')}
    />

    <div class="mx-auto mt-10 flex max-w-4xl flex-col items-center text-center md:mt-14">
      <p class="detail-reveal text-[0.72rem] uppercase tracking-[0.22em] text-accent">
        {albumTitle} — {pad(index)}
      </p>
      <h1 class="detail-reveal mt-4 font-serif text-[clamp(2.2rem,6vw,4.5rem)] leading-[1.05]">
        {title}
      </h1>
      {caption && <p class="detail-reveal mt-6 max-w-xl text-base leading-relaxed text-muted">{caption}</p>}
    </div>

    <nav
      class="mt-20 flex items-center justify-between gap-6 border-t border-line pt-8 text-[0.72rem] uppercase tracking-[0.2em] md:mt-28"
      aria-label="Photos"
    >
      <a
        href={`/${lang}/photo/${prev._id}/`}
        data-nav-dir="prev"
        class="group flex min-w-0 items-center gap-4 text-muted transition-colors duration-300 hover:text-ink"
      >
        <img
          class="detail-thumb shrink-0"
          src={urlFor(prev.image, 160, 112)}
          width="160"
          height="112"
          alt=""
          loading="lazy"
          decoding="async"
        />
        <span class="transition-transform duration-300 group-hover:-translate-x-1">←</span>
        <span class="hidden sm:inline">{t.prev}</span>
        <span class="truncate text-ink">{l(prev.title, lang)}</span>
      </a>
      <a
        href={`/${lang}/photo/${next._id}/`}
        data-nav-dir="next"
        class="group flex min-w-0 items-center justify-end gap-4 text-muted transition-colors duration-300 hover:text-ink"
      >
        <span class="truncate text-ink">{l(next.title, lang)}</span>
        <span class="hidden sm:inline">{t.next}</span>
        <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
        <img
          class="detail-thumb shrink-0"
          src={urlFor(next.image, 160, 112)}
          width="160"
          height="112"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </a>
    </nav>
  </article>
</Layout>
