---
import Layout from '../../layouts/Layout.astro';
import PhotoCard from '../../components/PhotoCard.astro';
import { getLocalePaths, l, ui, type LocaleCode } from '../../i18n/locales';
import { getCategories, getPhotos, getSiteSettings } from '../../lib/queries';

export function getStaticPaths() {
  return getLocalePaths();
}

const lang = Astro.params.lang as LocaleCode;
const t = ui[lang];

const [photos, categories, settings] = await Promise.all([
  getPhotos(),
  getCategories(),
  getSiteSettings(),
]);

// Photos per gallery, for the switcher counts.
const countBySlug = new Map<string, number>();
for (const p of photos) {
  const slug = p.category?.slug ?? 'other';
  countBySlug.set(slug, (countBySlug.get(slug) ?? 0) + 1);
}
const pad = (n: number) => String(n).padStart(2, '0');

// Editorial 12-column rhythm (desktop only): wide / narrow-offset pairs,
// repeating every 6. Below lg the grid is a clean 1- then 2-column stack.
// The `(min-width:640px) 48vw` step matches the 2-column tablet layout.
const pattern = [
  { span: 'lg:col-span-7 lg:col-start-1', sizes: '(min-width:1024px) 55vw, (min-width:640px) 48vw, 100vw' },
  { span: 'lg:col-span-4 lg:col-start-9 lg:mt-32', sizes: '(min-width:1024px) 32vw, (min-width:640px) 48vw, 100vw' },
  { span: 'lg:col-span-5 lg:col-start-2 lg:-mt-10', sizes: '(min-width:1024px) 40vw, (min-width:640px) 48vw, 100vw' },
  { span: 'lg:col-span-6 lg:col-start-7 lg:mt-24', sizes: '(min-width:1024px) 48vw, (min-width:640px) 48vw, 100vw' },
  { span: 'lg:col-span-8 lg:col-start-3 lg:mt-16', sizes: '(min-width:1024px) 64vw, (min-width:640px) 48vw, 100vw' },
  { span: 'lg:col-span-4 lg:col-start-1 lg:mt-20', sizes: '(min-width:1024px) 32vw, (min-width:640px) 48vw, 100vw' },
];
---

<Layout
  lang={lang}
  namespace="gallery"
  pageTitle={t.work}
  title={`${settings.photographerName} — ${t.work}`}
  photographerName={settings.photographerName}
>
  <!-- Hero -->
  <section class="flex min-h-[52svh] flex-col justify-end pb-16 md:pb-24" id="top">
    <p class="hero-line mb-5 text-[0.72rem] uppercase tracking-[0.24em] text-muted">
      {t.tagline}
    </p>
    <h1
      class="hero-title font-serif text-[clamp(3rem,11vw,9.5rem)] leading-[0.98] tracking-[-0.01em]"
      data-parallax="0.22"
    >
      <span data-split>{settings.photographerName}</span><span class="text-accent">.</span>
    </h1>
  </section>

  <!-- Gallery switcher -->
  <nav class="filter-bar mb-12 border-t border-line pt-6 md:mb-16" aria-label={t.galleries}>
    <p class="mb-4 text-[0.62rem] uppercase tracking-[0.3em] text-muted">{t.galleries}</p>
    <div class="flex flex-wrap gap-x-8 gap-y-4">
      <button type="button" class="filter-btn" data-filter="all" aria-pressed="true">
        <span class="filter-btn__label">{t.all}</span>
        <span class="filter-btn__count">{pad(photos.length)}</span>
      </button>
      {
        categories.map((cat) => (
          <button type="button" class="filter-btn" data-filter={cat.slug} aria-pressed="false">
            <span class="filter-btn__label">{l(cat.title, lang)}</span>
            <span class="filter-btn__count">{pad(countBySlug.get(cat.slug) ?? 0)}</span>
          </button>
        ))
      }
    </div>
  </nav>

  <!-- Photo grid -->
  <section class="photo-grid grid grid-cols-1 gap-y-12 sm:grid-cols-2 sm:gap-x-6 sm:gap-y-10 lg:grid-cols-12 lg:gap-x-8 lg:gap-y-8">
    {
      photos.map((photo, i) => (
        <PhotoCard
          photo={photo}
          lang={lang}
          class={pattern[i % pattern.length].span}
          sizes={pattern[i % pattern.length].sizes}
          eager={i < 2}
        />
      ))
    }
  </section>
</Layout>
