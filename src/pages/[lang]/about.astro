---
import Layout from '../../layouts/Layout.astro';
import { getLocalePaths, l, ui, type LocaleCode } from '../../i18n/locales';
import { getSiteSettings } from '../../lib/queries';

export function getStaticPaths() {
  return getLocalePaths();
}

const lang = Astro.params.lang as LocaleCode;
const t = ui[lang];
const settings = await getSiteSettings();
const bio = l(settings.bio, lang);

// Nick's Instagram is rendered from code (the seeded Site Settings only has a
// placeholder instagram.com link). Drop any Instagram from Sanity so exactly
// one — the correct handle — shows; other Sanity socials still render.
const INSTAGRAM_URL = 'https://www.instagram.com/shmily_5021991/';
const socials =
  settings.socialLinks?.filter((link) => link.url && !/instagram/i.test(link.url)) ?? [];
---

<Layout
  lang={lang}
  namespace="about"
  pageTitle={t.about}
  title={`${settings.photographerName} — ${t.about}`}
  photographerName={settings.photographerName}
>
  <section class="flex min-h-[70svh] flex-col justify-center py-20 md:py-28" id="top">
    <p class="about-reveal mb-8 text-[0.72rem] uppercase tracking-[0.24em] text-muted">
      {t.about}
    </p>

    {
      bio && (
        <p
          class="about-reveal max-w-3xl font-serif text-[clamp(1.5rem,3.4vw,2.6rem)] leading-[1.35]"
          data-parallax="0.12"
        >
          {bio}
        </p>
      )
    }

    <div class="about-reveal mt-16 flex flex-wrap items-baseline gap-x-12 gap-y-6 md:mt-24">
      {
        settings.contactEmail && (
          <a
            href={`mailto:${settings.contactEmail}`}
            class="group text-[0.78rem] uppercase tracking-[0.22em]"
          >
            <span class="mr-4 text-muted">{t.contact}</span>
            <span class="border-b-2 border-accent pb-1 transition-colors duration-300 group-hover:text-accent">
              {settings.contactEmail}
            </span>
          </a>
        )
      }
      {
        socials.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[0.78rem] uppercase tracking-[0.22em] text-muted transition-colors duration-300 hover:text-accent"
          >
            {link.label ?? link.url}
          </a>
        ))
      }
      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[0.78rem] uppercase tracking-[0.22em] text-muted transition-colors duration-300 hover:text-accent"
      >
        Instagram
      </a>
    </div>
  </section>
</Layout>
