---
import '../styles/global.css';
import nimbusSansRegularUrl from '../fonts/nimbus-sans/NimbusSans-Regular.woff2?url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localePathPattern, locales, ui, type LocaleCode } from '../i18n/locales';

interface Props {
  lang: LocaleCode;
  namespace: 'gallery' | 'about' | 'photo';
  /** Localized section name shown by the overlay transition. */
  pageTitle: string;
  title: string;
  description?: string;
  photographerName: string;
}

const { lang, namespace, pageTitle, title, description, photographerName } = Astro.props;

const htmlLang = locales.find((loc) => loc.code === lang)?.htmlLang ?? 'en';
// Path without the locale prefix, for hreflang alternates + the language switcher.
const basePath = Astro.url.pathname.replace(localePathPattern, '') || '/';
---

<html lang={htmlLang} class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description ?? ui[lang].metaDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="preload" href={nimbusSansRegularUrl} as="font" type="font/woff2" crossorigin />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    {
      locales.map((loc) => (
        <link
          rel="alternate"
          hreflang={loc.htmlLang}
          href={new URL(`/${loc.code}${basePath === '/' ? '/' : basePath}`, Astro.site)}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={new URL(`/en${basePath === '/' ? '/' : basePath}`, Astro.site)} />
    <script is:inline>
      document.documentElement.classList.remove('no-js');
      // Theme before first paint: saved choice, else system preference.
      (function () {
        var saved = localStorage.getItem('theme');
        if (saved === 'dark' || (!saved && matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
  </head>
  <body>
    <div data-barba="wrapper">
      <div
        data-barba="container"
        data-barba-namespace={namespace}
        data-page-title={pageTitle}
        class="min-h-svh bg-paper"
      >
        <div class="mx-auto flex min-h-svh max-w-[1600px] flex-col px-5 md:px-10">
          <Header lang={lang} basePath={basePath} photographerName={photographerName} />
          <main class="flex-1">
            <slot />
          </main>
          <Footer lang={lang} photographerName={photographerName} />
        </div>
      </div>
    </div>

    <!-- Wave transition overlay (GreenSock morphSVG pen adaptation) -->
    <svg
      class="transition-wave"
      viewBox="0 0 100 100"
      preserveAspectRatio="xMidYMin slice"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id="wave-grad" x1="0" y1="0" x2="99" y2="99" gradientUnits="userSpaceOnUse">
          <stop class="transition-wave__stop" offset="0.2" stop-color="#a87e2f"></stop>
          <stop class="transition-wave__stop" offset="0.85" stop-color="#e2c078"></stop>
        </linearGradient>
      </defs>
      <path
        class="transition-wave__path"
        fill="url(#wave-grad)"
        d="M 0 100 V 100 Q 50 100 100 100 V 100 z"></path>
    </svg>

    <!-- Custom cursor (JS enables it on fine pointers only) -->
    <div class="cursor" aria-hidden="true">
      <div class="cursor-ring"><div class="cursor-ring__circle"><span class="cursor-label"></span></div></div>
      <div class="cursor-dot"><div class="cursor-dot__circle"></div></div>
    </div>

    <script>
      import '../scripts/app';
    </script>
  </body>
</html>
