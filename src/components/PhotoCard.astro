---
import { l, type LocaleCode } from '../i18n/locales';
import type { Photo } from '../lib/queries';
import { srcsetFor, urlFor } from '../lib/image';

interface Props {
  photo: Photo;
  lang: LocaleCode;
  class?: string;
  sizes: string;
  eager?: boolean;
}

const { photo, lang, class: className, sizes, eager = false } = Astro.props;
const title = l(photo.title, lang);
const caption = l(photo.caption, lang);
const aspect = photo.image.width / photo.image.height;
---

<figure class:list={['photo-card group', className]} data-category={photo.category?.slug}>
  <div
    class="photo-media relative overflow-hidden rounded-[2px]"
    style={`aspect-ratio: ${photo.image.width} / ${photo.image.height}; background-image: url(${photo.image.lqip})`}
  >
    <img
      class="photo-img absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.025]"
      src={urlFor(photo.image, 1080)}
      srcset={srcsetFor(photo.image)}
      sizes={sizes}
      width={photo.image.width}
      height={photo.image.height}
      alt={caption ? `${title} — ${caption}` : title}
      loading={eager ? 'eager' : 'lazy'}
      fetchpriority={eager ? 'high' : 'auto'}
      decoding="async"
      style={`aspect-ratio: ${aspect}`}
    />
  </div>
  <figcaption class="mt-3 flex items-baseline justify-between gap-4 text-[0.72rem] uppercase tracking-[0.18em]">
    <span class="text-paper">{title}</span>
    <span class="text-muted">{l(photo.category?.title, lang)}</span>
  </figcaption>
</figure>
