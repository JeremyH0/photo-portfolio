---
import { l, ui, type LocaleCode } from '../i18n/locales';
import type { Photo } from '../lib/queries';
import { srcsetFor, urlFor } from '../lib/image';

interface Props {
  photo: Photo;
  lang: LocaleCode;
  class?: string;
  sizes: string;
  eager?: boolean;
  /** Accent color for this photo's category (CSS color). */
  accent: string;
}

const { photo, lang, class: className, sizes, eager = false, accent } = Astro.props;
const title = l(photo.title, lang);
const caption = l(photo.caption, lang);
---

<figure
  class:list={['photo-card group', className]}
  data-category={photo.category?.slug}
  style={`--cat: ${accent}`}
>
  <a
    href={`/${lang}/photo/${photo._id}/`}
    data-photo-link={photo._id}
    data-cursor-label={ui[lang].view}
    aria-label={title}
  >
    <div
      class="photo-media relative overflow-hidden rounded-[2px]"
      style={`aspect-ratio: ${photo.image.width} / ${photo.image.height}; background-image: url(${photo.image.lqip})`}
    >
      <img
        class="photo-img absolute inset-0 h-full w-full object-cover"
        src={urlFor(photo.image, 1080)}
        srcset={srcsetFor(photo.image)}
        sizes={sizes}
        width={photo.image.width}
        height={photo.image.height}
        alt={caption ? `${title} — ${caption}` : title}
        loading={eager ? 'eager' : 'lazy'}
        fetchpriority={eager ? 'high' : 'auto'}
        decoding="async"
      />
    </div>
  </a>
  <figcaption class="mt-3 flex items-baseline justify-between gap-4 text-[0.72rem] uppercase tracking-[0.18em]">
    <span class="text-ink">{title}</span>
    <span class="cat-accent">{l(photo.category?.title, lang)}</span>
  </figcaption>
</figure>
